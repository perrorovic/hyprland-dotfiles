{
  "workbench.tree.enableStickyScroll": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.navigationControl.enabled": false,
  "workbench.activityBar.location": "top",
  "workbench.startupEditor": "none",

  "window.customTitleBarVisibility": "auto",
  "window.zoomLevel": -0.5,

  "explorer.confirmDelete": false,
  "telemetry.telemetryLevel": "off",
  "extensions.autoUpdate": false,

  "editor.fontSize": 13,
  "editor.tabSize": 2,
  "editor.fontFamily": "'JetbrainsMono Nerd Font','Maple Mono', monospace",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorBlinking": "phase",
  "editor.stickyScroll.scrollWithEditor": false,
  "editor.smoothScrolling": true,
  "editor.scrollbar.verticalScrollbarSize": 0,
  "editor.cursorSurroundingLines": 12,

  "editor.minimap.enabled": false,
  "editor.minimap.scale": 1,
  "editor.minimap.maxColumn": 80,
  "editor.minimap.renderCharacters": true,
  
  "security.workspace.trust.untrustedFiles": "newWindow",
  "security.workspace.trust.startupPrompt": "never",
  "security.workspace.trust.enabled": false,
  
  "terminal.integrated.fontSize": 13,
  "terminal.external.linuxExec": "fish",
  "terminal.explorerKind": "both",
  "terminal.sourceControlRepositoriesKind": "both",
  "terminal.integrated.smoothScrolling": true,
  
  "vim.useSystemClipboard": true,
  "vim.foldfix": true,
  "vim.scrolloff": 12,
  "vim.visualModeKeyBindings": [
    // Repeateable indentation
    {"before": [">"], "commands": ["editor.action.indentLines"]},
    {"before": ["<"], "commands": ["editor.action.outdentLines"]},
    // Moving block vertically
    {"before": ["J"], "commands": ["editor.action.moveLinesDownAction"], "after": ["g", "v"]},
    {"before": ["K"], "commands": ["editor.action.moveLinesUpAction"]}
  ],
  "vim.ignorecase": true,
  "vim.smartcase": true,
  "vim.easymotion": true,
  "vim.hlsearch": true,

  "remote.SSH.enableDynamicForwarding": false,
  "remote.SSH.useLocalServer": false,
  "remote.SSH.remotePlatform": {},

  "window.commandCenter": false,
  "chat.agentsControl.enabled": false,
  "extensions.ignoreRecommendations": true,
  "editor.foldingStrategy": "indentation"
}