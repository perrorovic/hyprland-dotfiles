// Place your key bindings in this file to override the defaults
[
  {"key": "ctrl+o", "command": "workbench.action.terminal.toggleTerminal"},
  {"key": "shift+space", "command": "workbench.action.quickOpen"},
  {"key": "ctrl+space", "command": "workbench.action.showCommands"},
  {"key": "ctrl+=", "command": "editor.action.fontZoomIn"},
  {"key": "ctrl+-", "command": "editor.action.fontZoomOut"},
  {"key": "ctrl+0", "command": "editor.action.fontZoomReset"},
  {"key": "ctrl+h", "command": "workbench.action.toggleSidebarVisibility", "when": ""},
  {"key": "ctrl+l", "command": "workbench.action.toggleAuxiliaryBar", "when": ""}
]